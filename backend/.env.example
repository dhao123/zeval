# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/zkh_bench
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/zkh_bench

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=zkh-bench
MINIO_SECURE=false

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# LLM API Keys
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

ZHK_API_KEY=your-zhk-api-key
ZHK_BASE_URL=https://api.zkh.com/v1

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
